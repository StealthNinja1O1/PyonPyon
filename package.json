{
  "name": "pyonpyon",
  "workspaces": [
    "src/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build --compile --minify --bytecode --compile-exec-argv=\"--smol\" --define __COMPILED__=true ./src/index.ts --outfile pyonpyon",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/newsreader": "^5.2.10",

    "@resvg/resvg-js": "^2.6.2",
    "bun-types": "^1.3.14",
    "@discordeno/bot": "^21.0.0",
    "react": "^19.2.6",
    "satori": "^0.10.13"
  }
}
